# Host-level Caddyfile — unified reverse proxy for all services on the VPS
# Install location: /etc/caddy/Caddyfile
#
# This file replaces:
#   - webfixeet/deploy/Caddyfile.snippet (fixeet.co)
#   - webaigent/deploy/Caddyfile (aigent.biz)
#   - aigent/scripts/config_server/Caddyfile (meetr.aigent.biz, meetr.fixeet.co)
#
# After editing: sudo systemctl reload caddy

# ===========================================================================
# Fixeet website (Next.js in Docker, port 3001)
# ===========================================================================
fixeet.co {
    # CMS admin — redirect /admin to /admin/ (bare path doesn't match handle_path)
    redir /admin /admin/ permanent

    # CMS admin — serve static files from host filesystem
    # (Next.js standalone mode doesn't serve public/ files)
    handle_path /admin/* {
        root * /opt/webfixeet/public/admin
        file_server
    }

    reverse_proxy localhost:3001

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Cache static assets
    @static path /static/* /_next/static/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Compression
    encode gzip zstd
}

www.fixeet.co {
    redir https://fixeet.co{uri} permanent
}

# ===========================================================================
# Fixeet CMS OAuth proxy (for Sveltia/Decap CMS GitHub authentication)
# ===========================================================================
cms-auth.fixeet.co {
    reverse_proxy localhost:3003
}

# ===========================================================================
# AIgent website (Next.js in Docker, port 3002)
# ===========================================================================
aigent.biz {
    # CMS admin — serve static files directly from the repo
    redir /admin /admin/ permanent
    handle_path /admin/* {
        root * /opt/webaigent/public/admin
        try_files {path} /index.html
        file_server
    }

    reverse_proxy localhost:3002

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Cache static assets
    @static path /static/* /_next/static/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Compression
    encode gzip zstd
}

www.aigent.biz {
    redir https://aigent.biz{uri} permanent
}

# ===========================================================================
# CMS OAuth proxy for Sveltia/Decap CMS (Docker, port 3003)
# ===========================================================================
cms-auth.aigent.biz {
    reverse_proxy localhost:3003
}

# ===========================================================================
# Meetr platform (FastAPI services in Docker, ports 8000-8002 + Grafana 3000)
# ===========================================================================
meetr.aigent.biz, meetr.fixeet.co {
    # callr API — strip /callr prefix before forwarding
    handle_path /callr/* {
        reverse_proxy localhost:8000
    }

    # meetr API routes
    handle /api/* {
        reverse_proxy localhost:8001
    }

    # meetr web app routes
    handle /app/* {
        reverse_proxy localhost:8001
    }

    # Health check endpoint
    handle /health* {
        reverse_proxy localhost:8001
    }

    # Prometheus metrics endpoint
    handle /metrics {
        reverse_proxy localhost:8001
    }

    # Admin UI
    handle /admin/* {
        reverse_proxy localhost:8001
    }

    # OpenAPI docs (FastAPI auto-generated)
    handle /docs {
        reverse_proxy localhost:8001
    }
    handle /redoc {
        reverse_proxy localhost:8001
    }
    handle /openapi.json {
        reverse_proxy localhost:8001
    }

    # Sample app — strip /sample_app prefix before forwarding
    handle_path /sample_app/* {
        reverse_proxy localhost:8002
    }
    # Redirect /sample_app to /sample_app/
    redir /sample_app /sample_app/ permanent

    # Grafana monitoring dashboard — keep /monitor prefix
    handle /monitor/* {
        reverse_proxy localhost:3000
    }

    # Default: serve static frontend (future SPA)
    handle {
        root * /srv/meetr-app
        try_files {path} /index.html
        file_server
    }
}
