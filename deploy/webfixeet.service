[Unit]
Description=WebFixeet Website (Next.js in Docker)
After=docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/opt/webfixeet
ExecStart=/usr/bin/docker compose -f deploy/docker-compose.prod.yml up
ExecStop=/usr/bin/docker compose -f deploy/docker-compose.prod.yml down
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=webfixeet

[Install]
WantedBy=multi-user.target
